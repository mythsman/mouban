{{define "explore.tmpl"}}
<!doctype html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>功能入口 - mouban</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css" />
    <link rel="stylesheet" href="/static/app.css" />
</head>
<body>
<main class="container">
    <header class="topbar">
        <a class="brand" href="/">mouban</a>
        <nav class="topbar-nav">
            <a href="/">首页</a>
            <a href="/explore" class="active">功能入口</a>
            <a href="/explore/users">用户查询</a>
            <a href="/explore/queue">调度队列</a>
        </nav>
    </header>

    <section class="intro-card">
        <h1>功能入口</h1>
        <p class="muted">选择你要使用的模块。</p>
        <div class="feature-grid">
            <article>
                <h3>用户查询</h3>
                <p>输入 Douban UID / domain / 用户名（精确匹配），进入用户详情并继续浏览条目。</p>
                <a role="button" href="/explore/users">进入用户查询</a>
            </article>

            <article>
                <h3>调度队列</h3>
                <p>查看抓取队列状态、执行中任务和最近完成记录，支持跳转到用户/条目详情。</p>
                <a role="button" href="/explore/queue">进入队列看板</a>
            </article>
        </div>
    </section>
</main>
</body>
</html>
{{end}}
